{
  "name": "lumen-vscode",
  "displayName": "Lumen",
  "description": "Workspace home and schema-driven editor for Modal AI pipelines",
  "version": "0.1.3",
  "publisher": "vladpazych",
  "preview": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vladpazych/lumen.git"
  },
  "homepage": "https://github.com/vladpazych/lumen",
  "bugs": {
    "url": "https://github.com/vladpazych/lumen/issues"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "modal",
    "ai",
    "image generation",
    "video generation",
    "inference pipelines",
    "vibe coding"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lumen.openPreview",
        "title": "Lumen: Open Preview"
      },
      {
        "command": "lumen.startServer",
        "title": "Lumen: Start Server"
      },
      {
        "command": "lumen.stopServer",
        "title": "Lumen: Stop Server"
      },
      {
        "command": "lumen.openAsJson",
        "title": "Lumen: Open as JSON"
      },
      {
        "command": "lumen.initWorkspace",
        "title": "Lumen: Init Workspace"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "lumen.initWorkspace"
        },
        {
          "command": "lumen.openPreview",
          "when": "resourceFilename =~ /\\.lumen$/"
        },
        {
          "command": "lumen.openAsJson",
          "when": "resourceFilename =~ /(^lumen\\.config\\.json$)|(/\\.lumen$/)"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "lumen.stateViewer",
        "displayName": "Lumen",
        "selector": [
          {
            "filenamePattern": "*.lumen"
          },
          {
            "filenamePattern": "lumen.config.json"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Lumen",
      "properties": {
        "lumen.logFile": {
          "type": "string",
          "default": "",
          "description": "Absolute path to mirror all Lumen logs (extension + dev server). Useful for LLM-assisted debugging. Leave empty to disable."
        },
        "lumen.server": {
          "type": "string",
          "default": "server",
          "description": "Path to the inference server source directory. Supports ${workspaceFolder}. The extension starts/stops the dev server and auto-detects the URL from Modal output."
        }
      }
    }
  },
  "scripts": {
    "dev": "bun run dev.ts",
    "watch": "bun build src/extension.ts --outdir dist --target node --format cjs --external vscode --sourcemap=linked --watch & vite build --watch",
    "build": "bun build src/extension.ts --outdir dist --target node --format cjs --external vscode --sourcemap=linked && vite build",
    "package": "bun run build && bunx @vscode/vsce package --no-dependencies -o dist/lumen-vscode.vsix",
    "reinstall": "bun run package && code --install-extension dist/lumen-vscode.vsix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json"
  },
  "dependencies": {
    "@vladpazych/lumen": "workspace:*"
  },
  "devDependencies": {
    "@repo/meta-config": "workspace:*",
    "@base-ui/react": "^1.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.560.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.3.0"
  }
}
