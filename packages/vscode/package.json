{
  "name": "lumen-vscode",
  "displayName": "Lumen",
  "description": "Schema-driven editor for .lumen files",
  "version": "0.0.0",
  "private": true,
  "publisher": "vladpazych",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lumen.openPreview",
        "title": "Lumen: Open Preview"
      },
      {
        "command": "lumen.startServer",
        "title": "Lumen: Start Server"
      },
      {
        "command": "lumen.stopServer",
        "title": "Lumen: Stop Server"
      },
      {
        "command": "lumen.openAsJson",
        "title": "Lumen: Open as JSON"
      },
      {
        "command": "lumen.setFalApiKey",
        "title": "Lumen: Set fal.ai API Key"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "lumen.openPreview",
          "when": "resourceFilename =~ /\\.lumen$/"
        },
        {
          "command": "lumen.openAsJson",
          "when": "resourceFilename =~ /\\.lumen$/"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "lumen.stateViewer",
        "displayName": "Lumen",
        "selector": [
          {
            "filenamePattern": "*.lumen"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Lumen",
      "properties": {
        "lumen.serverUrls": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Deployed Lumen server URLs (grab yours from https://modal.com/apps)"
        },
        "lumen.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to lumen-example-modal directory (for local dev). Requires lumen.devServerUrl to be set."
        },
        "lumen.devServerUrl": {
          "type": "string",
          "default": "",
          "description": "URL of the local dev server (e.g. http://localhost:8000). Required alongside lumen.serverPath for dev server to appear."
        }
      }
    }
  },
  "scripts": {
    "dev": "bun run dev.ts",
    "watch": "bun build src/extension.ts --outdir dist --target node --format cjs --external vscode --sourcemap=linked --watch & vite build --watch",
    "build": "bun build src/extension.ts --outdir dist --target node --format cjs --external vscode --sourcemap=linked && vite build",
    "package": "bun run build && bunx @vscode/vsce package --no-dependencies -o dist/lumen-vscode.vsix",
    "reinstall": "bun run package && code --install-extension dist/lumen-vscode.vsix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json"
  },
  "devDependencies": {
    "@base-ui/react": "^1.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.560.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.3.0"
  }
}
