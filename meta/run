#!/bin/sh
# Meta CLI wrapper. Runs repo dexter commands via Bun.
#
# Emergency brake: touch .codex/hooks-disabled to bypass all hook handlers.
# Remove the file after fixing: rm .codex/hooks-disabled

DIR="$(cd "${0%/*}" 2>/dev/null && pwd)"
ROOT="${DIR%/meta}"

# Hook commands (on-*): check emergency brake
case "$1" in
  on-*)
    [ -f "$ROOT/.codex/hooks-disabled" ] && exit 0
    ;;
esac

if command -v bun >/dev/null 2>&1; then
  BUN_BIN="$(command -v bun)"
elif [ -x "$HOME/.bun/bin/bun" ]; then
  BUN_BIN="$HOME/.bun/bin/bun"
else
  echo "meta/run: bun is required but was not found on PATH or at \$HOME/.bun/bin/bun" >&2
  exit 127
fi

exec "$BUN_BIN" run --cwd "$ROOT" dexter "$@"
